{
  "manifest_version": 3,
  "name": "SEO Slider Auditor Pro",
  "version": "1.1.0",
  "description": "Panel lateral avanzado para auditoría SEO y accesibilidad en tiempo real.",
  "permissions": ["sidePanel", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Abrir Auditor SEO"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
  //commit
}